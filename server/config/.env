PORT=5000
MONGODB_URI=mongodb://localhost:27017/ecommerce_app
JWT_PRIVATE_KEY_FILENAME=server/config/jwt_private_key.pem
NODE_ENV=development
ACCESS_LEVEL_GUEST=0
ACCESS_LEVEL_NORMAL_USER=1
ACCESS_LEVEL_ADMIN=2
JWT_EXPIRY=7d
PASSWORD_HASH_SALT_ROUNDS=3
UPLOADED_FILES_FOLDER=./uploads
LOCAL_HOST=http://localhost:3000